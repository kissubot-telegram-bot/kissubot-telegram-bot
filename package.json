{
  "name": "kisu1bot-telegram-bot",
  "version": "1.0.0",
  "main": "bot.js",
  "scripts": {
    "start": "node server.js",
    "dev": "node bot.js",
    "test": "jest --testPathPattern=tests/ --forceExit --detectOpenHandles",
    "test:unit": "jest --testPathPattern=tests/unit --forceExit",
    "test:integration": "jest --testPathPattern=tests/integration --forceExit",
    "test:coverage": "jest --coverage --testPathPattern=tests/ --forceExit"
  },
  "jest": {
    "testEnvironment": "node",
    "testTimeout": 15000,
    "moduleNameMapper": {
      "^dotenv$": "<rootDir>/tests/__mocks__/dotenv.js"
    }
  },
  "dependencies": {
    "axios": "^1.5.7",
    "body-parser": "^1.20.2",
    "cloudinary": "^1.41.0",
    "concurrently": "^9.2.1",
    "dotenv": "^16.0.0",
    "express": "^4.18.2",
    "form-data": "^4.0.3",
    "mongoose": "^7.5.0",
    "multer": "^1.4.5-lts.1",
    "multer-storage-cloudinary": "^4.0.0",
    "ngrok": "^5.0.0-beta.2",
    "node-telegram-bot-api": "^0.61.0"
  },
  "devDependencies": {
    "jest": "^30.2.0",
    "supertest": "^7.2.2"
  }
}
