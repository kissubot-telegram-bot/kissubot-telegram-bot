# Telegram Bot
BOT_TOKEN=your_telegram_bot_token_here
WEBHOOK_URL=https://your-domain.com

# Telegram Payments (Telegram Stars — XTR)
# Leave empty to use Telegram Stars (no provider setup needed)
# OR get a provider token from BotFather → /mybots → Payments → Stripe
TELEGRAM_PAYMENT_TOKEN=

# MongoDB
MONGODB_URI=mongodb+srv://user:password@cluster.mongodb.net/dbname

# Cloudinary (profile photo storage)
CLOUDINARY_CLOUD_NAME=your_cloud_name
CLOUDINARY_API_KEY=your_api_key
CLOUDINARY_API_SECRET=your_api_secret

# API Base URL
API_BASE=http://localhost:3000

# Admin Telegram IDs (comma-separated)
ADMIN_IDS=123456789,987654321
